          "datasource": { "type": "postgres", "uid": "postgres-dwh" },
          "format": "table",
          "rawSql": "SELECT source, SUM(nb_articles) AS total FROM mv_articles_par_jour WHERE full_date >= NOW() - INTERVAL '7 days' GROUP BY source ORDER BY total DESC",
